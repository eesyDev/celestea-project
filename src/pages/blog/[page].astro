---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { categoryNames } from '../../data/categories';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection('blog');
  const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(sortedPosts, { pageSize: 12 });
}

const { page } = Astro.props;
const uniqueCategories = [...new Set((await getCollection('blog')).map((post) => post.data.category))].filter(Boolean);
---

<MainLayout
  title={`Блог — Страница ${page.currentPage} | Celestea`}
  description="Статьи об астрологии, эзотерике, демонологии и нумерологии. Практические разборы и прогнозы."
  breadcrumbs={[{ name: 'Главная', url: '/' }, { name: 'Блог', url: '/blog/' }]}
  pageType="CollectionPage"
>
  <Header />
  <main class="blog-listing">
    <div class="container">

      <div class="blog-listing__header">
        <p class="pre-title">Все материалы</p>
        <h1 class="h1">Блог</h1>
        <p class="blog-listing__subtitle">Астрология, эзотерика, ритуалы и символика — разборы без воды</p>
      </div>

      <div class="blog-listing__filters">
        {uniqueCategories.map((category) => (
          <a href={`/category/${category}/1`} class="category-pill">
            {categoryNames[category] || category}
          </a>
        ))}
      </div>

      <div class="posts-grid">
        {page.data.map((post) => (
          <PostCard post={post} />
        ))}
      </div>

      <Pagination page={page} />
    </div>
  </main>
  <Footer />
</MainLayout>

<style>
.blog-listing {
  padding: 60px 0 80px;
}
.blog-listing__header {
  text-align: center;
  margin-bottom: 48px;
}
.blog-listing__header .pre-title {
  margin-bottom: 12px;
}
.blog-listing__subtitle {
  margin-top: 16px;
  font-size: 1.05rem;
  color: #7a7a8c;
  max-width: 480px;
  margin-left: auto;
  margin-right: auto;
}
.blog-listing__filters {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
  margin-bottom: 48px;
}
.category-pill {
  padding: 8px 22px;
  border: 1px solid var(--gold);
  color: var(--dark-blue);
  font-size: 0.875rem;
  font-weight: 500;
  transition: all 0.2s ease;
  text-decoration: none;
}
.category-pill:hover {
  background-color: var(--gold);
  color: #fff;
}
.posts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  margin-bottom: 60px;
}
@media (max-width: 1024px) {
  .posts-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .posts-grid { grid-template-columns: 1fr; }
  .blog-listing { padding: 40px 0 60px; }
}
</style>
