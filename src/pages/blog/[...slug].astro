---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';

// 1. Astro генерирует пути для всех статей
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

function extractFAQ(body: string): Array<{question: string; answer: string}> {
  const section = body.match(/##\s*Часто задаваемые вопросы([\s\S]*?)(?=\n##\s|$)/)?.[1] ?? '';
  const items: Array<{question: string; answer: string}> = [];
  const re = /\*\*([^*\n]+)\*\*\n([^\n*][^\n]*)/g;
  let m: RegExpExecArray | null;
  while ((m = re.exec(section)) !== null) {
    items.push({ question: m[1].trim(), answer: m[2].trim() });
  }
  return items;
}

const faqItems = extractFAQ(entry.body);
const slug = entry.data.slug ?? entry.slug;
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(post => post.slug !== entry.slug)
  .filter(post => post.data.category === entry.data.category)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<MainLayout
    title={`${entry.data.title} | Celestea`}
    description={entry.data.description}
    image={entry.data.image}
    type="article"
    pubDate={new Date(entry.data.pubDate)}
    noindex={entry.data.noindex ?? false}
    breadcrumbs={[
        { name: 'Главная', url: '/' },
        { name: 'Блог', url: '/blog/' },
        { name: entry.data.title, url: `/blog/${slug}/` },
    ]}
    tags={entry.data.tags}
    faqItems={faqItems.length > 0 ? faqItems : undefined}
>
    <Header/>
        <article class="article-content">
            <div class="container container-sm">
                {entry.data.image && (
                    entry.data.category === 'tarot'
                        ? <img src={entry.data.image} alt={entry.data.title} class="tarot-card-img" />
                        : <img src={entry.data.image} alt={entry.data.title} class="article-hero-img" />
                )}

                <Content />

                <div class="article-author">
                    <img src="/favicon.png" alt="Celestea" class="article-author__avatar" />
                    <div>
                        <a href="/author/" class="article-author__name">Алина Островерхова</a>
                        <span class="article-author__role">Астролог и автор проекта</span>
                    </div>
                </div>
            </div>
        </article>

        {relatedPosts.length > 0 && (
          <section class="related-posts">
            <div class="container">
              <div class="heading" style="text-align:center; margin: 0 auto 48px; max-width: 480px;">
                <p class="pre-title">Читайте также</p>
                <h2 class="h2">Похожие статьи</h2>
              </div>
              <div class="related-posts__grid">
                {relatedPosts.map(post => (
                  <PostCard post={post} />
                ))}
              </div>
            </div>
          </section>
        )}

  <Footer/>
</MainLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const article = document.querySelector('.article-content');
    if (!article) return;

    // Ищем заголовок FAQ
    const headings = article.querySelectorAll('h2');
    let faqHeading = null;
    for (const h of headings) {
      if (h.textContent.includes('Часто задаваемые вопросы')) {
        faqHeading = h;
        break;
      }
    }
    if (!faqHeading) return;

    // Собираем все элементы до следующего h2 или конца
    const elements = [];
    let el = faqHeading.nextElementSibling;
    while (el && el.tagName !== 'H2') {
      elements.push(el);
      el = el.nextElementSibling;
    }

    // Вопрос — <p>, первый дочерний элемент которого <strong>
    function isQuestion(el) {
      return el.tagName === 'P' &&
        el.children.length > 0 &&
        el.children[0].tagName === 'STRONG';
    }

    // Текст ответа, который идёт в той же строке после <strong> (soft line break)
    function getInlineAnswer(p) {
      const strong = p.children[0];
      let text = '';
      let node = strong.nextSibling;
      while (node) {
        text += node.textContent || '';
        node = node.nextSibling;
      }
      return text.trim();
    }

    const faqContainer = document.createElement('div');
    faqContainer.className = 'faq-accordion';

    let i = 0;
    while (i < elements.length) {
      const current = elements[i];

      if (isQuestion(current)) {
        const details = document.createElement('details');
        const summary = document.createElement('summary');
        summary.textContent = current.children[0].textContent;
        details.appendChild(summary);

        const answerDiv = document.createElement('div');
        answerDiv.className = 'faq-answer';

        // Ответ может быть в той же <p> после <strong> (если нет пустой строки в md)
        const inlineText = getInlineAnswer(current);
        if (inlineText) {
          const p = document.createElement('p');
          p.textContent = inlineText;
          answerDiv.appendChild(p);
        }

        i++;
        // Собираем следующие элементы как часть ответа до следующего вопроса
        while (i < elements.length && !isQuestion(elements[i])) {
          answerDiv.appendChild(elements[i].cloneNode(true));
          i++;
        }

        details.appendChild(answerDiv);
        faqContainer.appendChild(details);
      } else {
        i++;
      }
    }

    faqHeading.after(faqContainer);
    elements.forEach(el => el.remove());
  });
</script>