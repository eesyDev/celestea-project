---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import zodiacs from '../../data/zodiacs.json';
import compatibilityData from '../../data/compatibility.json';

  export async function getStaticPaths() {
  return zodiacs.map((sign) => ({
    params: { sign: sign.slug }, 
    props: { signData: sign },  
  }));
}

const getImageName = (slug) => {
    const map = { 'virgo': 'virgin', 'sagittarius': 'saggitarius', 'pisces': 'pieces' };
    return map[slug] || slug;
};
  const { signData } = Astro.props;

const nameToSlug = zodiacs.reduce((acc, item) => {
    acc[item.name] = item.slug;
    return acc;
}, {});

const getSignLinks = (str) => {
    if (!str) return [];
    return str.split(',').map(name => {
        const cleanName = name.trim(); // Убираем лишние пробелы
        return {
            name: cleanName,
            href: `/zodiac/${nameToSlug[cleanName] || ''}` // Если вдруг опечатка, ссылка будет пустой
        };
    });
};

const bestMatches = getSignLinks(signData.details.best_match);
const worstMatches = getSignLinks(signData.details.worst_match);

// Related posts: match by sign name, element or ruling planet in tags
const allPosts = await getCollection('blog');
const keywords = [
  signData.name,
  signData.element,
  signData.details.ruling_planet,
].map(k => k.toLowerCase());

const relatedPosts = allPosts
  .filter(post => {
    const tags = (post.data.tags ?? []).map(t => t.toLowerCase());
    return tags.some(tag => keywords.some(kw => tag.includes(kw)));
  })
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

// Fallback: fill up to 3 with recent karma/planets posts not already included
if (relatedPosts.length < 3) {
  const relatedSlugs = new Set(relatedPosts.map(p => p.slug));
  const fallback = allPosts
    .filter(p => !relatedSlugs.has(p.slug) && ['karma', 'planets', 'horoscope'].includes(p.data.category))
    .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
    .slice(0, 3 - relatedPosts.length);
  relatedPosts.push(...fallback);
}

// Совместимость: все пары для этого знака
const compatPairs = compatibilityData
  .filter(d => d.sign1 === signData.slug || d.sign2 === signData.slug)
  .map(d => {
    const otherName = d.sign1 === signData.slug ? d.sign2_name : d.sign1_name;
    return { href: `/compatibility/${d.pair}/`, name: otherName, score: d.score_overall };
  })
  .sort((a, b) => b.score - a.score);

const scoreColor = (score: number) => {
  if (score >= 5) return '#4caf50';
  if (score >= 4) return '#8bc34a';
  if (score === 3) return '#ffc107';
  if (score === 2) return '#ff9800';
  return '#f44336';
};
---
<MainLayout title={signData.seo_title} description={signData.seo_desc}>
    <Header />
    <main class="zodiac-single">
        <div class="container">
            <div class="zodiac-hero" style="text-align: center; margin-bottom: 50px;">
                <img 
                    src={`/assets/img/${getImageName(signData.slug)}.png`} 
                    srcset={`/assets/img/${getImageName(signData.slug)}_2x.png 2x`}
                    alt={signData.name}
                    style="width: 120px; height: 120px; margin-bottom: 20px;"
                />
                <h1 class="h1">{signData.name}</h1>
                <p style="font-size: 1.2rem; opacity: 0.7; margin-top: 10px;">{signData.dates}</p>
                
                <div class="tags" style="display: flex; justify-content: center; gap: 15px; margin-top: 20px;">
                    <span class="tag">Стихия: {signData.element}</span>
                    <span class="tag">Планета: {signData.planet}</span>
                </div>
            </div>
            <div class="zodiac-grid">
                <article class="main-content">
                    <h4 class="h4">Общая характеристика</h4>
                    <p>{signData.about}</p>
                    <div class="spacer spacer--40"></div>
                    <h4 class="h4">Мужчина {signData.name}</h4>
                    <p>{signData.man}</p>
     
                    <div class="spacer spacer--40"></div>
     
                    <h4 class="h4">Женщина {signData.name}</h4>
                    <p>{signData.woman}</p>
     
                    <div class="spacer spacer--40"></div>
     
                    <h4 class="h4">Любовь и отношения</h4>
                    <p>{signData.love}</p>
                    <div class="spacer spacer--40"></div>

                    <h4 class="h4">Карьера и деньги 💰</h4>
                    <p>{signData.career}</p>

                    <div class="spacer spacer--40"></div>

                    <h4 class="h4">Здоровье и тонус 🍏</h4>
                    <p>{signData.health}</p>

                    <div class="spacer spacer--40"></div>

                    <h4 class="h4">Сексуальность 🔥</h4>
                    <p>{signData.sex}</p>
                    
                    <div class="spacer spacer--40"></div>

                    <h4 class="h4">Семья и дети 👨‍👩‍👧‍👦</h4>
                    <p>{signData.family}</p>
                </article>

                <aside class="zodiac-sidebar">
                    <div class="fact-card">
                        <h4 class="h4 zodiac-sidebar-sub">Астро-факты</h4>
                        <ul class="fact-list">
                            <li>
                                <strong>Планета:</strong> <span>{signData.details.ruling_planet}</span>
                            </li>
                            <li>
                                <strong>Камень:</strong> <span>{signData.details.lucky_stone}</span>
                            </li>
                            <li>
                                <strong>Цвета:</strong> <span>{signData.details.lucky_colors.join(', ')}</span>
                            </li>
                            <li>
                                <strong>Числа:</strong> <span>{signData.details.lucky_numbers.join(', ')}</span>
                            </li>
                            <li class="separator"></li>
                            <li class="good-match">
                                <strong>❤️ Совместимость:</strong>
                                <div class="links-wrapper">
                                    {bestMatches.map((link, index) => (
                                        <>
                                            <a href={link.href} class="zodiac-link good">{link.name}</a>
                                            {index < bestMatches.length - 1 && ", "}
                                        </>
                                    ))}
                                </div>
                            </li>
                            <li class="bad-match">
                                <strong>⚠️ Сложно с:</strong>
                                <div class="links-wrapper">
                                    {worstMatches.map((link, index) => (
                                        <>
                                            <a href={link.href} class="zodiac-link bad">{link.name}</a>
                                            {index < worstMatches.length - 1 && ", "}
                                        </>
                                    ))}
                                </div>
                            </li>
                        </ul>
                    </div>
                </aside>
            </div>
        </div>
    </main>

    {compatPairs.length > 0 && (
      <section class="py-10">
        <div class="container">
          <h2 class="text-2xl font-bold text-center mb-8">Совместимость {signData.name} с другими знаками</h2>
          <div class="compat-zodiac-grid">
            {compatPairs.map(pair => (
              <a href={pair.href} class="compat-zodiac-item compat-card">
                <span class="compat-zodiac-name">{pair.name}</span>
                <span class="compat-zodiac-score" style={`color:${scoreColor(pair.score)}`}>
                  {'★'.repeat(pair.score)}{'☆'.repeat(5 - pair.score)}
                </span>
              </a>
            ))}
          </div>
          <div style="text-align:center; margin-top: 24px;">
            <a href="/compatibility/" class="btn btn--outlined">Все пары совместимости</a>
          </div>
        </div>
      </section>
    )}

    {relatedPosts.length > 0 && (
      <section class="py-10">
        <div class="container">
          <h2 class="text-2xl font-bold text-center mb-8">Статьи для {signData.name}</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-8">
            {relatedPosts.map(post => (
              <PostCard post={post} />
            ))}
          </div>
        </div>
      </section>
    )}

    <Footer/>
</MainLayout>
