---
// src/layouts/MainLayout.astro
import '../styles/global.css';

interface Props {
    title?: string;
    description?: string;
    image?: string;
    type?: 'website' | 'article';
    pubDate?: Date;
    dateModified?: Date;
    noindex?: boolean;
    breadcrumbs?: Array<{name: string; url: string}>;
    tags?: string[];
    faqItems?: Array<{question: string; answer: string}>;
    pageType?: 'WebPage' | 'AboutPage' | 'ContactPage' | 'CollectionPage';
}

const {
    title = 'Celestea — астрология, гороскопы и знаки зодиака',
    description = 'Астрологический портал Celestea: персональные гороскопы, знаки зодиака, натальные карты, совместимость и лунные циклы.',
    image,
    type = 'website',
    pubDate,
    dateModified,
    noindex = false,
    breadcrumbs,
    tags,
    faqItems,
    pageType = 'WebPage',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image
    ? new URL(image, Astro.site).href
    : new URL('/assets/img/og-default.jpg', Astro.site).href;

const siteUrl = Astro.site!.href;
const pageUrl = canonicalURL.href;
const orgId = `${siteUrl}#organization`;
const websiteId = `${siteUrl}#website`;
const pageId = `${pageUrl}#webpage`;
const authorId = `${siteUrl}author/#person`;

const graph: object[] = [
    {
        '@type': 'Organization',
        '@id': orgId,
        name: 'Celestea',
        url: siteUrl,
        logo: `${siteUrl}favicon.png`,
        description: 'Эзотерический и астрологический портал на русском языке: астрология, нумерология, демонология, знаки зодиака и лунные практики.',
    },
    {
        '@type': 'WebSite',
        '@id': websiteId,
        url: siteUrl,
        name: 'Celestea',
        publisher: { '@id': orgId },
        inLanguage: 'ru-RU',
    },
    {
        '@type': pageType,
        '@id': pageId,
        url: pageUrl,
        name: title,
        description: description,
        isPartOf: { '@id': websiteId },
        publisher: { '@id': orgId },
        inLanguage: 'ru-RU',
        ...(dateModified ? { dateModified: dateModified.toISOString() } : {}),
    },
];

if (breadcrumbs && breadcrumbs.length > 0) {
    graph.push({
        '@type': 'BreadcrumbList',
        '@id': `${pageUrl}#breadcrumb`,
        itemListElement: breadcrumbs.map((crumb, i) => ({
            '@type': 'ListItem',
            position: i + 1,
            name: crumb.name,
            item: new URL(crumb.url, Astro.site).href,
        })),
    });
}

if (type === 'article') {
    graph.push({
        '@type': 'Person',
        '@id': authorId,
        name: 'Алина Островерхова',
        url: `${siteUrl}author/`,
        worksFor: { '@id': orgId },
    });
    graph.push({
        '@type': 'BlogPosting',
        '@id': `${pageUrl}#article`,
        headline: title,
        description: description,
        image: ogImage,
        datePublished: pubDate?.toISOString(),
        dateModified: dateModified?.toISOString() ?? pubDate?.toISOString(),
        author: { '@id': authorId },
        publisher: { '@id': orgId },
        mainEntityOfPage: { '@id': pageId },
        inLanguage: 'ru-RU',
        ...(tags && tags.length > 0 ? {
            mentions: tags.map(tag => ({ '@type': 'DefinedTerm', name: tag })),
        } : {}),
    });
}

if (faqItems && faqItems.length > 0) {
    graph.push({
        '@type': 'FAQPage',
        '@id': `${pageUrl}#faq`,
        mainEntity: faqItems.map(item => ({
            '@type': 'Question',
            name: item.question,
            acceptedAnswer: { '@type': 'Answer', text: item.answer },
        })),
    });
}

const jsonLd = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph });
---
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="alternate" type="application/rss+xml" title="Celestea — новые статьи" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <title>{title}</title>
    <meta name="description" content={description}>
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="Celestea" />
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={jsonLd} />

    <meta name="yandex-verification" content="c3c96ffae6072e47" />
