---
const { page } = Astro.props;
---

<nav class="pagination-nav" aria-label="Pagination">
  {page.url.prev ? (
    <a href={page.url.prev} class="pagination-btn pagination-btn--active">
      &larr; Назад
    </a>
  ) : (
    <span class="pagination-btn pagination-btn--disabled">&larr; Назад</span>
  )}

  <span class="pagination-info">
    {page.currentPage} / {page.lastPage}
  </span>

  {page.url.next ? (
    <a href={page.url.next} class="pagination-btn pagination-btn--active">
      Вперёд &rarr;
    </a>
  ) : (
    <span class="pagination-btn pagination-btn--disabled">Вперёд &rarr;</span>
  )}
</nav>

<style>
.pagination-nav {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16px;
  margin-top: 48px;
  padding-bottom: 16px;
}
.pagination-btn {
  padding: 10px 28px;
  font-size: 0.9rem;
  font-weight: 500;
  border: 1px solid var(--gold);
  text-decoration: none;
  transition: all 0.2s ease;
}
.pagination-btn--active {
  color: var(--dark-blue);
  background: transparent;
}
.pagination-btn--active:hover {
  background: var(--gold);
  color: #fff;
}
.pagination-btn--disabled {
  color: #c0c0cc;
  border-color: #ddd;
  cursor: not-allowed;
}
.pagination-info {
  font-size: 0.875rem;
  color: #9b9baa;
  min-width: 56px;
  text-align: center;
}
</style>
